# Ollama configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Discord bot configuration (optional - required only for Discord interface)
DISCORD_TOKEN=your-discord-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here

# Web server configuration (optional - required only for Web interface)
WEB_PORT=3000
WEB_HOST=localhost

# Obsidian Vault path (optional - enables vault search when set)
VAULT_PATH=/path/to/your/obsidian/vault

# Chat interface to launch: cli | discord | web | all
# Defaults to cli if not set
INTERFACE=cli

# System prompt customization (optional)
# SYSTEM_PROMPT=You are Zypher Ghost, a Shadowrun AI assistant...

# Conversation history limit (number of messages to keep in context)
HISTORY_LIMIT=20
