{
  "name": "zypher-ghost",
  "version": "1.0.0",
  "description": "Shadowrun AI Assistant powered by Ollama — CLI, Discord, and Web chat interfaces with Obsidian Vault integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "start:cli": "INTERFACE=cli tsx src/index.ts",
    "start:web": "INTERFACE=web tsx src/index.ts",
    "start:discord": "INTERFACE=discord tsx src/index.ts",
    "build": "tsgo && yarn build:client",
    "build:client": "vite build --config src/interfaces/web/client/vite.config.ts",
    "dev:client": "vite dev --config src/interfaces/web/client/vite.config.ts",
    "start:prod": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "shadowrun",
    "ollama",
    "discord",
    "llm",
    "ai",
    "obsidian"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "glob": "^11.1.0",
    "ollama": "^0.6.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "beta",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "tsx": "^4.21.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
